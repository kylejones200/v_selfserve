# --- Firebase (Google Sign-In) ---
# Create a project at https://console.firebase.google.com/, enable "Authentication" > "Sign-in method" > "Google".
# Get the config from Project settings > General > Your apps > SDK setup and config.
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
# Optional; from Firebase Console > Your apps > appId
# VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# --- Backend only (server/.env or same .env when running node server) ---
# Claude: get key at https://console.anthropic.com/
LLM_API_KEY=your-anthropic-api-key
# Same as VITE_FIREBASE_API_KEY (Firebase Web API key), used to verify tokens
FIREBASE_API_KEY=your-firebase-api-key

# Optional: if your API runs on another origin in production, set in .env:
# VITE_API_URL=https://your-api.example.com
